# ============================================================
# MEME Perp DEX - 24h Testnet Environment Configuration
# ============================================================
# Copy this file to .env.testnet and fill in the sensitive values
# DO NOT commit .env.testnet to version control!
# ============================================================

# Blockchain
CHAIN_ID=97
RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/
WSS_URL=wss://bsc-testnet-rpc.publicnode.com
BLOCK_EXPLORER=https://testnet.bscscan.com
ALCHEMY_RPC_URL=<YOUR_ALCHEMY_RPC_URL>

# Contract Addresses (BSC Testnet - Latest Deployment 2026-03-03)
SETTLEMENT_V2_ADDRESS=0x7fF9d60aE49F14bB604FeF1961910D7931067873
SETTLEMENT_V1_ADDRESS=0x63df8d6acF3f99Ae59Bee6184A5EB6beA8663eb7
PERP_VAULT_ADDRESS=0x7F98ed779c3352f39b041C57d5B2C73F84dcAA75
PRICE_FEED_ADDRESS=0xe2b22673fFBeB7A2a4617125E885C12EC072ee48
TOKEN_FACTORY_ADDRESS=0x22276744bAF24eD503dB50Cc999a9c5AD62728cb
WBNB_ADDRESS=0xae13d989daC2f0dEbFf460aC112a837C89BAa7cd
# Legacy V1 addresses (deprecated but kept for reference)
# VAULT_ADDRESS=
# POSITION_MANAGER_ADDRESS=
# LIQUIDATION_ADDRESS=
# FUNDING_RATE_ADDRESS=

# SENSITIVE - Replace with your own values
MATCHER_PRIVATE_KEY=<YOUR_MATCHER_PRIVATE_KEY>
FEE_RECEIVER_ADDRESS=<YOUR_FEE_RECEIVER_ADDRESS>
JWT_SECRET=<YOUR_JWT_SECRET_MIN_32_CHARS>

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<YOUR_DB_PASSWORD>
POSTGRES_DB=memeperp
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# Service Ports
MATCHING_ENGINE_PORT=8081
BACKEND_PORT=8080
FRONTEND_PORT=3000

# Matching Engine
BATCH_INTERVAL_MS=30000
MIN_BATCH_SIZE=1
MAX_BATCH_SIZE=50
SKIP_SIGNATURE_VERIFY=false
LOG_LEVEL=info

# Frontend
NEXT_PUBLIC_MATCHING_ENGINE_URL=http://localhost:8081
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_PUBLIC_URL=ws://localhost:8080/ws/public
NEXT_PUBLIC_WS_PRIVATE_URL=ws://localhost:8080/ws/private
NEXT_PUBLIC_CHAIN_ID=97
NEXT_PUBLIC_SETTLEMENT_ADDRESS=0x7fF9d60aE49F14bB604FeF1961910D7931067873
NEXT_PUBLIC_DEV_MODE=true
NEXT_PUBLIC_TESTNET=true
