# Frontend Environment Variables Template
# =========================================
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to version control

# API Configuration
# -----------------
# Backend API URL (REQUIRED in production)
# Development: http://localhost:8080
# Production: https://api.memeperp.xyz
NEXT_PUBLIC_API_URL=http://localhost:8080

# WebSocket Configuration
# -----------------------
# Development: ws://localhost:8080/ws
# Production:  wss://api.memeperp.xyz/ws
NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:8080/ws

# WalletConnect Project ID
# ------------------------
# Get your project ID from https://cloud.walletconnect.com/
# Required for WalletConnect QR code scanning
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Perpetual Trading Contract Addresses (BSC Mainnet)
# ---------------------------------------------------------------------
# Settlement contract (V2 peer-to-peer trading)
# This is the main contract for the new architecture
NEXT_PUBLIC_SETTLEMENT_ADDRESS=your_settlement_address_here

# Vault contract (legacy margin custody)
NEXT_PUBLIC_VAULT_ADDRESS=your_vault_address_here

# Position Manager contract (legacy, migration mode)
NEXT_PUBLIC_POSITION_MANAGER_ADDRESS=your_position_manager_address_here

# Insurance Fund address
NEXT_PUBLIC_INSURANCE_FUND_ADDRESS=your_insurance_fund_address_here

# Matching Engine Configuration (V2 Architecture)
# ------------------------------------------------
# URL for the matching engine API (handles order matching off-chain)
# Development: http://localhost:8081
# Production: https://matching.memeperp.xyz
NEXT_PUBLIC_MATCHING_ENGINE_URL=http://localhost:8081

# Enable V2 trading mode (peer-to-peer Settlement)
# Set to "true" to use the new V2 architecture
NEXT_PUBLIC_USE_V2_TRADING=false

# Network Configuration
# ---------------------
# BSC Mainnet
NEXT_PUBLIC_BSC_RPC_URL=https://bsc-dataseed.binance.org/
NEXT_PUBLIC_CHAIN_ID=56
NEXT_PUBLIC_TARGET_CHAIN_ID=56

# Block Explorer URL
NEXT_PUBLIC_BLOCK_EXPLORER_URL=https://bscscan.com

# WBNB Address (BSC Mainnet)
NEXT_PUBLIC_WETH_ADDRESS=0xbb4CdB9CBd36B01bD1cBaEBF2De08d9173bc095c
NEXT_PUBLIC_WBNB_ADDRESS=0xbb4CdB9CBd36B01bD1cBaEBF2De08d9173bc095c

# Zero-fee DEXI Swap routes through PancakeSwap V2 on BSC.
# DEXI platform fee is 0 bps; Pancake LP/router fees are included in the quote.
NEXT_PUBLIC_USDT_ADDRESS=0x55d398326f99059fF775485246999027B3197955
NEXT_PUBLIC_PANCAKE_V2_ROUTER_ADDRESS=0x10ED43C718714eb63d5aA57B78B54704E256024E

# =========================================
# SECURITY NOTES:
# 1. NEVER put private keys in frontend environment variables
# 2. All signing operations should be done on the backend
# 3. Use wss:// (not ws://) in production for encrypted WebSocket
# 4. Rotate API keys regularly
# 5. Use secrets management (AWS Secrets Manager, Vault) for production
# =========================================
