# Production Environment Variables Template
# Copy this file to .env.production and fill in the values
# NEVER commit .env.production to version control

# =============================================================
# Database Configuration
# =============================================================
POSTGRES_PASSWORD=your-secure-database-password-here
REDIS_PASSWORD=your-secure-redis-password-here

# =============================================================
# Security
# =============================================================
JWT_SECRET=your-256-bit-jwt-secret-here

# =============================================================
# Blockchain Configuration
# =============================================================
# Use a reliable RPC provider (Alchemy, Infura, QuickNode)
RPC_URL=https://bsc-dataseed.binance.org/

# Chain ID (56 for BSC Mainnet, 97 for BSC Testnet)
CHAIN_ID=56

# Keeper wallet private key (without 0x prefix)
# WARNING: This should be a dedicated keeper wallet, not your main wallet
# In production, consider using AWS KMS or HashiCorp Vault
KEEPER_PRIVATE_KEY=your-keeper-private-key-without-0x-prefix

# =============================================================
# Contract Addresses (BSC Mainnet — ALL REQUIRED, no fallbacks)
# =============================================================
# Fill these in after running DeployBSCMainnet.s.sol
# The matching engine and frontend will REFUSE TO START if any are missing.

# Core perpetual contracts
VAULT_ADDRESS=
POSITION_ADDRESS=
SETTLEMENT_V2_ADDRESS=
PERP_VAULT_ADDRESS=
PRICE_FEED_ADDRESS=
FUNDING_RATE_ADDRESS=
LIQUIDATION_ADDRESS=
INSURANCE_FUND_ADDRESS=

# Spot contracts
TOKEN_FACTORY_ADDRESS=

# Collateral token (WBNB on BSC Mainnet)
COLLATERAL_TOKEN_ADDRESS=0xbb4CdB9CBd36B01bD1cBaEBF2De08d9173bc095c

# Lending
LENDING_POOL_ADDRESS=

# Platform fee receiver (your revenue wallet)
FEE_RECEIVER_ADDRESS=

# Frontend-specific addresses (duplicate for NEXT_PUBLIC_ prefix)
MEMEPERP_TOKEN_FACTORY_ADDRESS=${TOKEN_FACTORY_ADDRESS}
MEMEPERP_SETTLEMENT_ADDRESS=${POSITION_ADDRESS}
MEMEPERP_SETTLEMENT_V2_ADDRESS=${SETTLEMENT_V2_ADDRESS}
MEMEPERP_BLOCKCHAIN_VAULT_ADDRESS=${VAULT_ADDRESS}
MEMEPERP_BLOCKCHAIN_PRICE_FEED_ADDRESS=${PRICE_FEED_ADDRESS}
MEMEPERP_PERP_VAULT_ADDRESS=${PERP_VAULT_ADDRESS}
MEMEPERP_INSURANCE_FUND_ADDRESS=${INSURANCE_FUND_ADDRESS}
MEMEPERP_LENDING_POOL_ADDRESS=${LENDING_POOL_ADDRESS}
MEMEPERP_LIQUIDATION_ADDRESS=${LIQUIDATION_ADDRESS}
MEMEPERP_FUNDING_RATE_ADDRESS=${FUNDING_RATE_ADDRESS}
MEMEPERP_BLOCKCHAIN_POSITION_ADDRESS=${POSITION_ADDRESS}

# =============================================================
# API URLs
# =============================================================
API_URL=https://api.memeperp.xyz
WS_URL=wss://api.memeperp.xyz/ws

# =============================================================
# Optional: Monitoring & Alerting
# =============================================================
# SENTRY_DSN=https://xxx@sentry.io/xxx
# DATADOG_API_KEY=xxx
# PAGERDUTY_KEY=xxx
